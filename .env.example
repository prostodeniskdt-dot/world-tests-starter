# PostgreSQL connection string
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/world_tests"

# Включить SSL для подключения к БД (true/false)
# Используйте true для облачных провайдеров (timeweb.cloud и т.д.)
DB_SSL="false"
# По умолчанию true. Для Timeweb/облака с self-signed цепочкой: DB_SSL_REJECT_UNAUTHORIZED="false"
# DB_SSL_REJECT_UNAUTHORIZED="true"
# Опционально: PEM сертификат CA (для rejectUnauthorized: true)
# DB_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# JWT Secret — ОБЯЗАТЕЛЕН в production (минимум 32 символа, случайная строка)
# Сгенерировать: openssl rand -base64 48
JWT_SECRET=""

# URL приложения (для ссылок в email). На продакшене — итоговый адрес (например https://your-app.twc1.net)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Сброс пароля по email (когда подключите SendGrid/Resend)
RESET_EMAIL_ENABLED="false"

# Redis для rate limiting при нескольких инстансах (опционально)
# REDIS_URL="redis://localhost:6379"

# S3 (Timeweb Object Storage) — для загрузки изображений в каталогах
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""
S3_ENDPOINT="https://s3.twcstorage.ru"
S3_REGION="ru-1"
S3_PUBLIC_URL=""
