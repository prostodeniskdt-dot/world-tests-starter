# PostgreSQL connection string
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/world_tests"

# Включить SSL для подключения к БД (true/false)
# Используйте true для облачных провайдеров (timeweb.cloud и т.д.)
DB_SSL="false"

# JWT Secret для аутентификации (любая длинная случайная строка)
JWT_SECRET="your-secret-key-change-in-production"

# URL приложения (для ссылок в email и CORS). На продакшене — итоговый адрес (например https://your-app.twc1.net)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# S3 (Timeweb Object Storage) — для загрузки изображений в каталогах
# Создайте бакет в панели Timeweb Cloud, настройте CORS и публичный доступ
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""
S3_ENDPOINT="https://s3.twcstorage.ru"
S3_REGION="ru-1"
# Публичный URL бакета (если привязан домен — укажите его)
S3_PUBLIC_URL=""
